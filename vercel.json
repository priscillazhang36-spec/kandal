{
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "^/$",
      "dest": "/public/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ],
  "crons": [
    {
      "path": "/matches/run",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/matches/rescue",
      "schedule": "*/30 * * * *"
    }
  ]
}
